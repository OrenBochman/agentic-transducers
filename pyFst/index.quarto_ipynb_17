    "#| label: fst-morph-analyzer\n",
    "#| echo: true\n",
    "\n",
    "from pathlib import Path\n",
    "import subprocess\n",
    "\n",
    "import pynini\n",
    "import pywrapfst\n",
    "from IPython.display import Image, display\n",
    "\n",
    "\n",
    "def x(inp: str, out: str):\n",
    "    return pynini.cross(inp, out)\n",
    "\n",
    "\n",
    "def byte_symbol_table(text: str):\n",
    "    syms = pywrapfst.SymbolTable()\n",
    "    syms.add_symbol(\"<eps>\", 0)\n",
    "    for ch in sorted(set(text)):\n",
    "        syms.add_symbol(ch, ord(ch))\n",
    "    return syms\n",
    "\n",
    "\n",
    "def apply_fst(fst, text: str):\n",
    "    lattice = pynini.accep(text) @ fst\n",
    "    try:\n",
    "        return pynini.shortestpath(lattice).string()\n",
    "    except pywrapfst.FstOpError:\n",
    "        return None\n",
    "\n",
    "\n",
    "# running -> run+ing\n",
    "running = (\n",
    "    x(\"r\", \"r\")\n",
    "    + x(\"u\", \"u\")\n",
    "    + x(\"n\", \"n\")\n",
    "    + x(\"n\", \"+\")\n",
    "    + x(\"i\", \"i\")\n",
    "    + x(\"n\", \"n\")\n",
    "    + x(\"g\", \"g\")\n",
    ")\n",
    "\n",
    "# jumping -> jump+ing\n",
    "jumping = (\n",
    "    x(\"j\", \"j\")\n",
    "    + x(\"u\", \"u\")\n",
    "    + x(\"m\", \"m\")\n",
    "    + x(\"p\", \"p\")\n",
    "    + x(\"i\", \"+i\")\n",
    "    + x(\"n\", \"n\")\n",
    "    + x(\"g\", \"g\")\n",
    ")\n",
    "\n",
    "# happiness -> happy+ness\n",
    "# here the surface i maps back to lexical y,\n",
    "# and the following n outputs +n\n",
    "happiness = (\n",
    "    x(\"h\", \"h\")\n",
    "    + x(\"a\", \"a\")\n",
    "    + x(\"p\", \"p\")\n",
    "    + x(\"p\", \"p\")\n",
    "    + x(\"i\", \"y\")\n",
    "    + x(\"n\", \"+n\")\n",
    "    + x(\"e\", \"e\")\n",
    "    + x(\"s\", \"s\")\n",
    "    + x(\"s\", \"s\")\n",
    ")\n",
    "\n",
    "fst = (running | jumping | happiness).optimize()\n",
    "\n",
    "# Make labels readable in the DOT/PNG.\n",
    "all_symbols = (\n",
    "    \"runningrun+ing\"\n",
    "    \"jumpingjump+ing\"\n",
    "    \"happinesshappy+ness\"\n",
    ")\n",
    "syms = byte_symbol_table(all_symbols)\n",
    "\n",
    "dot_path = Path(\"fst_morphology.dot\")\n",
    "png_path = Path(\"fst_morphology.png\")\n",
    "\n",
    "fst.draw(\n",
    "    str(dot_path),\n",
    "    portrait=True,\n",
    "    isymbols=syms,\n",
    "    osymbols=syms,\n",
    ")\n",
    "\n",
    "subprocess.run(\n",
    "    [\"dot\", \"-Tpng\", str(dot_path), \"-o\", str(png_path)],\n",
    "    check=True,\n",
    ")\n",
    "\n",
    "# Show a few analyses\n",
    "tests = [\"running\", \"jumping\", \"happiness\", \"runner\"]\n",
    "for w in tests:\n",
    "    print(f\"{w:10s} -> {apply_fst(fst, w)}\")\n",
    "\n",
    "display(Image(filename=str(png_path)))"
