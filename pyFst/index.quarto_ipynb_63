    "#| label: fst-running-analyzer\n",
    "#| echo: true\n",
    "\n",
    "from pathlib import Path\n",
    "import subprocess\n",
    "\n",
    "import pynini\n",
    "import pywrapfst\n",
    "from IPython.display import Image, display\n",
    "\n",
    "\n",
    "def x(inp: str, out: str):\n",
    "    \"\"\"One-symbol transducer.\"\"\"\n",
    "    return pynini.cross(inp, out)\n",
    "\n",
    "\n",
    "def byte_symbol_table(chars: str):\n",
    "    \"\"\"\n",
    "    Pynini's default labels are byte integers.\n",
    "    This table makes DOT/Graphviz show readable symbols.\n",
    "    \"\"\"\n",
    "    syms = pywrapfst.SymbolTable()\n",
    "    syms.add_symbol(\"<eps>\", 0)\n",
    "\n",
    "    for ch in sorted(set(chars)):\n",
    "        syms.add_symbol(ch, ord(ch))\n",
    "\n",
    "    return syms\n",
    "\n",
    "\n",
    "def apply_fst(fst, text: str):\n",
    "    \"\"\"\n",
    "    Apply FST to text and return the output string.\n",
    "    Returns None if the input is rejected.\n",
    "    \"\"\"\n",
    "    lattice = pynini.accep(text) @ fst\n",
    "\n",
    "    try:\n",
    "        return pynini.shortestpath(lattice).string()\n",
    "    except pywrapfst.FstOpError:\n",
    "        return None\n",
    "\n",
    "\n",
    "# Morphological analyzer:\n",
    "# running -> run+ing\n",
    "#\n",
    "# The second \"n\" is the doubled consonant.\n",
    "# It is consumed as input and output as \"+\".\n",
    "fst = (\n",
    "    x(\"r\", \"r\")\n",
    "    + x(\"u\", \"u\")\n",
    "    + x(\"n\", \"n\")\n",
    "    + x(\"n\", \"+\")\n",
    "    + x(\"i\", \"i\")\n",
    "    + x(\"n\", \"n\")\n",
    "    + x(\"g\", \"g\")\n",
    ").optimize()\n",
    "\n",
    "symbols = byte_symbol_table(\"runig+\")\n",
    "\n",
    "dot_path = Path(\"fst_running_analyzer.dot\")\n",
    "png_path = Path(\"fst_running_analyzer.png\")\n",
    "\n",
    "fst.draw(\n",
    "    str(dot_path),\n",
    "    portrait=True,\n",
    "    isymbols=symbols,\n",
    "    osymbols=symbols,\n",
    ")\n",
    "\n",
    "subprocess.run(\n",
    "    [\"dot\", \"-Tpng\", str(dot_path), \"-o\", str(png_path)],\n",
    "    check=True,\n",
    ")\n",
    "\n",
    "print(\"running ->\", apply_fst(fst, \"running\"))\n",
    "\n",
    "display(Image(filename=str(png_path)))"
