digraph FST {
rankdir = LR;
size = "8.5,11";
center = 1;
orientation = Portrait;
ranksep = "0.4";
nodesep = "0.25";
0 [label = "0", shape = circle, style = bold, fontsize = 14]
	0 -> 1 [label = "r:r", fontsize = 14];
1 [label = "1", shape = circle, style = solid, fontsize = 14]
	1 -> 2 [label = "u:u", fontsize = 14];
2 [label = "2", shape = circle, style = solid, fontsize = 14]
	2 -> 3 [label = "n:n", fontsize = 14];
3 [label = "3", shape = circle, style = solid, fontsize = 14]
	3 -> 4 [label = "n:+", fontsize = 14];
4 [label = "4", shape = circle, style = solid, fontsize = 14]
	4 -> 5 [label = "i:i", fontsize = 14];
5 [label = "5", shape = circle, style = solid, fontsize = 14]
	5 -> 6 [label = "n:n", fontsize = 14];
6 [label = "6", shape = circle, style = solid, fontsize = 14]
	6 -> 7 [label = "g:g", fontsize = 14];
7 [label = "7", shape = doublecircle, style = solid, fontsize = 14]
}
