    "#| label: fst-morphology\n",
    "#| echo: true\n",
    "\n",
    "import subprocess\n",
    "from pathlib import Path\n",
    "\n",
    "import pynini\n",
    "\n",
    "\n",
    "def x(inp: str, out: str):\n",
    "    return pynini.cross(inp, out)\n",
    "\n",
    "\n",
    "def make_byte_symbol_table(chars: str):\n",
    "    \"\"\"\n",
    "    Pynini's default string mode is byte-like for ASCII strings.\n",
    "    So the labels are ord(char), e.g. ord(\"r\") == 114.\n",
    "    \"\"\"\n",
    "    syms = pynini.SymbolTable()\n",
    "    syms.add_symbol(\"<eps>\", 0)\n",
    "\n",
    "    for ch in sorted(set(chars)):\n",
    "        syms.add_symbol(ch, ord(ch))\n",
    "\n",
    "    return syms\n",
    "\n",
    "\n",
    "# r (u|n)* i (n|g)*\n",
    "fst = (\n",
    "    x(\"r\", \"r\")\n",
    "    + pynini.closure(x(\"u\", \"u\") | x(\"n\", \"n\"))\n",
    "    + x(\"i\", \"i\")\n",
    "    + pynini.closure(x(\"n\", \"n\") | x(\"g\", \"g\"))\n",
    ").optimize()\n",
    "\n",
    "symbols = make_byte_symbol_table(\"runig\")\n",
    "\n",
    "dot_path = Path(\"fst_morphology.dot\")"
   ]
