   "source": [
    "import pynini\n",
    "\n",
    "o_to_a = pynini.cross(\"o\", \"a\")\n",
    "one_or_more_o_to_a = o_to_a + pynini.closure(o_to_a)\n",
    "\n",
    "rule = pynini.cross(\"m\", \"b\") + one_or_more_o_to_a + pynini.cross(\"?\", \"!\")\n",
    "\n",
    "for s in [\"mo?\", \"moo?\", \"mooo?\"]:\n",
    "    print(s, \"->\", pynini.shortestpath(s @ rule).string())"
   ]
