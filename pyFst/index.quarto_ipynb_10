    "```\n",
    "\n",
    "\n",
    "\n",
    "```python\n",
    "input_sequence = list(\"running\")\n",
    "\n",
    "# Initialize the FST\n",
    "current_state = fst.start\n",
    "output_sequence = []\n",
    "\n",
    "# Process the input\n",
    "for symbol in input_sequence:\n",
    "    for arc in fst[current_state].arcs:\n",
    "        if arc.ilabel == symbol:\n",
    "            output_sequence.append(arc.olabel)\n",
    "            current_state = arc.nextstate\n",
    "            break\n",
    "\n",
    "# Check if the final state is reached\n",
    "if fst[current_state].final:\n",
    "    print(\"Input:\", \"\".join(input_sequence))\n",
    "    print(\"Output:\", \"\".join(output_sequence))\n",
    "else:\n",
    "    print(\"Input not accepted by the FST.\")\n",
    "```"
