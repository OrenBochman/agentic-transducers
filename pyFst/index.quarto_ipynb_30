        "#| label: morph-lexicon-rules-analyzer\n",
        "#| echo: true\n",
        "\n",
        "from pathlib import Path\n",
        "import string\n",
        "import subprocess\n",
        "\n",
        "import pandas as pd\n",
        "import pynini\n",
        "import pywrapfst\n",
        "from pynini.lib import pynutil\n",
        "from IPython.display import Image, display\n",
        "\n",
        "\n",
        "# ----------------------------\n",
        "# Helpers\n",
        "# ----------------------------\n",
        "\n",
        "def accep(s: str):\n",
        "    return pynini.accep(s)\n",
        "\n",
        "\n",
        "def word(prefix: str, stem: str, suffix: str):\n",
        "    \"\"\"\n",
        "    Build a lexical form from prefix, stem, suffix.\n",
        "\n",
        "    Examples:\n",
        "      word(\"\",   \"jump\",  \"ing\")  -> jump+ing\n",
        "      word(\"re\", \"run\",   \"ing\")  -> re+run+ing\n",
        "      word(\"un\", \"happy\", \"ness\") -> un+happy+ness\n",
        "    \"\"\"\n",
        "    p = accep(\"\") if prefix == \"\" else accep(prefix + \"+\")\n",
        "    return p + accep(stem) + accep(\"+\" + suffix)\n",
        "\n",
        "\n",
        "def byte_symbol_table(chars: str):\n",
        "    \"\"\"\n",
        "    Pynini's default ASCII labels are byte integers.\n",
        "    This table makes Graphviz show letters instead of numbers.\n",
        "    \"\"\"\n",
        "    syms = pywrapfst.SymbolTable()\n",
        "    syms.add_symbol(\"<eps>\", 0)\n",
        "    for ch in sorted(set(chars)):\n",
        "        syms.add_symbol(ch, ord(ch))\n",
        "    return syms\n",
        "\n",
        "\n",
        "def one_best(fst, text: str):\n",
        "    \"\"\"\n",
        "    Apply FST to text and return the best output string.\n",
        "    Returns None if the input is rejected.\n",
        "    \"\"\"\n",
        "    lattice = pynini.compose(accep(text), fst)\n",
        "\n",
        "    # No valid path.\n",
        "    if lattice.start() == pywrapfst.NO_STATE_ID:\n",
        "        return None\n",
        "\n",
        "    try:\n",
        "        path = pynini.shortestpath(lattice, nshortest=1, unique=True).optimize()\n",
        "\n",
        "        # Critical fix:\n",
        "        # convert the relation into its output string language.\n",
        "        path.project(\"output\")\n",
        "        path.rmepsilon()\n",
        "\n",
        "        return path.string()\n",
        "    except pywrapfst.FstOpError:\n",
        "        return None\n",
        "\n",
        "\n",
        "# ----------------------------\n",
        "# 1. Lexicon / morphotactics\n",
        "# ----------------------------\n",
        "\n",
        "LEXICON = pynini.union(\n",
        "    word(\"\",   \"run\",   \"er\"),     # run+er\n",
        "    word(\"\",   \"run\",   \"ing\"),    # run+ing\n",
        "    word(\"re\", \"run\",   \"ing\"),    # re+run+ing\n",
        "    word(\"\",   \"jump\",  \"ing\"),    # jump+ing\n",
        "    word(\"\",   \"happy\", \"ness\"),   # happy+ness\n",
        "    word(\"un\", \"happy\", \"ness\"),   # un+happy+ness\n",
        ").optimize()\n",
        "\n",
        "\n",
        "# ----------------------------\n",
        "# 2. Spelling rules\n",
        "# ----------------------------\n",
        "\n",
        "ALPHABET = string.ascii_lowercase + \"+\"\n",
        "SIGMA_STAR = pynini.union(*ALPHABET).closure().optimize()\n",
        "\n",
        "PLUS = accep(\"+\")\n",
        "ING = accep(\"ing\")\n",
        "NESS = accep(\"ness\")\n",
        "ER = accep(\"er\")\n",
        "\n",
        "\n",
        "# happy+ness -> happi+ness\n",
        "y_to_i_before_ness = pynini.cdrewrite(\n",
        "    pynini.cross(\"y\", \"i\"),\n",
        "    \"\",\n",
        "    PLUS + NESS,\n",
        "    SIGMA_STAR,\n",
        ").optimize()\n",
        "\n",
        "\n",
        "# run+er -> runn+er\n",
        "double_n_before_er = pynini.cdrewrite(\n",
        "    pynutil.insert(\"n\"),\n",
        "    accep(\"n\"),\n",
        "    PLUS + ER,\n",
        "    SIGMA_STAR,\n",
        ").optimize()\n",
        "\n",
        "# run+ing -> runn+ing\n",
        "double_n_before_ing = pynini.cdrewrite(\n",
        "    pynutil.insert(\"n\"),\n",
        "    accep(\"n\"),\n",
        "    PLUS + ING,\n",
        "    SIGMA_STAR,\n",
        ").optimize()\n",
        "\n",
        "\n",
        "# jump+ing -> jumping\n",
        "# re+runn+ing -> rerunning\n",
        "# un+happi+ness -> unhappiness\n",
        "delete_boundaries = pynini.cdrewrite(\n",
        "    pynutil.delete(\"+\"),\n",
        "    \"\",\n",
        "    \"\",\n",
        "    SIGMA_STAR,\n",
        ").optimize()\n",
        "\n",
        "\n",
        "# ----------------------------\n",
        "# 3. Generator and analyzer\n",
        "# ----------------------------\n",
        "\n",
        "GENERATOR = (\n",
        "    LEXICON\n",
        "    @ y_to_i_before_ness\n",
        "    @ double_n_before_er\n",
        "    @ double_n_before_ing\n",
        "    @ delete_boundaries\n",
        ").optimize()\n",
        "\n",
        "ANALYZER = GENERATOR.invert().optimize()\n",
        "\n",
        "\n",
        "# ----------------------------\n",
        "# 4. Test lexical -> surface\n",
        "# ----------------------------\n",
        "\n",
        "lexical_tests = [\n",
        "    \"run+er\",\n",
        "    \"run+ing\",\n",
        "    \"re+run+ing\",\n",
        "    \"jump+ing\",\n",
        "    \"happy+ness\",\n",
        "    \"un+happy+ness\",\n",
        "]\n",
        "\n",
        "gen_rows = [\n",
        "    {\"lexical\": x, \"surface\": one_best(GENERATOR, x)}\n",
        "    for x in lexical_tests\n",
        "]\n",
        "\n",
        "display(pd.DataFrame(gen_rows))\n",
        "\n",
        "\n",
        "# ----------------------------\n",
        "# 5. Test surface -> lexical analysis\n",
        "# ----------------------------\n",
        "\n",
        "surface_tests = [\n",
        "    \"run\",\n",
        "    \"jump\",\n",
        "    \"happy\"\n",
        "    \"unhappy\",\n",
        "    \"running\",\n",
        "    \"rerunning\",\n",
        "    \"jumping\",\n",
        "    \"happiness\",\n",
        "    \"unhappiness\",\n",
        "    \"runner\",\n",
        "]\n",
        "\n",
        "ana_rows = [\n",
        "    {\"surface\": x, \"analysis\": one_best(ANALYZER, x)}\n",
        "    for x in surface_tests\n",
        "]\n",
        "\n",
        "display(pd.DataFrame(ana_rows))\n",
        "\n",
        "\n",
        "# ----------------------------\n",
        "# 6. Draw analyzer as PNG\n",
        "# ----------------------------\n",
        "\n",
        "syms = byte_symbol_table(ALPHABET)\n",
        "\n",
        "dot_path = Path(\"morph_analyzer2.dot\")\n",
        "png_path = Path(\"morph_analyzer2.png\")\n",
        "\n",
        "ANALYZER.draw(\n",
        "    str(dot_path),\n",
        "    portrait=True,\n",
        "    isymbols=syms,\n",
        "    osymbols=syms,\n",
        ")\n",
        "\n",
        "subprocess.run(\n",
        "    [\"dot\", \"-Tpng\", str(dot_path), \"-o\", str(png_path)],\n",
        "    check=True,\n",
        ")\n",
        "\n",
        "#display(Image(filename=str(png_path)))"
      ],
