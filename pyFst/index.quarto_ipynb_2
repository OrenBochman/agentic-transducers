      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "```{python}\n",
        "#| label: fig-fst-morphology\n",
        "#| fig-cap: \"Toy morphology FST\"\n",
        "#| echo: true\n",
        "\n",
        "import subprocess\n",
        "from IPython.display import Image, display\n",
        "import pywrapfst as fst\n",
        "\n",
        "# Create symbol tables\n",
        "isyms = fst.SymbolTable()\n",
        "osyms = fst.SymbolTable()\n",
        "\n",
        "# OpenFst convention: epsilon gets label 0\n",
        "isyms.add_symbol(\"<eps>\", 0)\n",
        "osyms.add_symbol(\"<eps>\", 0)\n",
        "\n",
        "for sym in [\"r\", \"u\", \"n\", \"i\", \"g\"]:\n",
        "    isyms.add_symbol(sym)\n",
        "    osyms.add_symbol(sym)\n",
        "\n",
        "# Create an FST\n",
        "machine = fst.Fst()\n",
        "\n",
        "# Add states\n",
        "start_state = machine.add_state()\n",
        "mid_state = machine.add_state()\n",
        "final_state = machine.add_state()\n",
        "\n",
        "# Set start and final states\n",
        "machine.set_start(start_state)\n",
        "machine.set_final(final_state)\n",
        "\n",
        "# Helper for identity arcs: input symbol == output symbol\n",
        "one = fst.Weight.one(machine.weight_type())\n",
        "\n",
        "def add_arc(src, dst, inp, out):\n",
        "    machine.add_arc(\n",
        "        src,\n",
        "        fst.Arc(\n",
        "            isyms.find(inp),\n",
        "            osyms.find(out),\n",
        "            one,\n",
        "            dst,\n",
        "        ),\n",
        "    )\n",
        "\n",
        "# Add transitions\n",
        "add_arc(start_state, mid_state, \"r\", \"r\")\n",
        "add_arc(mid_state, mid_state, \"u\", \"u\")\n",
        "add_arc(mid_state, mid_state, \"n\", \"n\")\n",
        "add_arc(mid_state, final_state, \"i\", \"i\")\n",
        "add_arc(final_state, final_state, \"n\", \"n\")\n",
        "add_arc(final_state, final_state, \"g\", \"g\")\n",
        "\n",
        "# Attach symbol tables so labels render as characters\n",
        "machine.set_input_symbols(isyms)\n",
        "machine.set_output_symbols(osyms)\n",
        "\n",
        "# Draw DOT, then render PNG with Graphviz\n",
        "machine.draw(\"fst_morphology.dot\")\n",
        "\n",
        "subprocess.run(\n",
        "    [\"dot\", \"-Tpng\", \"fst_morphology.dot\", \"-o\", \"fst_morphology.png\"],\n",
        "    check=True,\n",
        ")\n",
        "\n",
        "display(Image(filename=\"fst_morphology.png\"))"
      ],
