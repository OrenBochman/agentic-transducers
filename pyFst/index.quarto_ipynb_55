        "#| label: fst-morph-epsilon-plus\n",
        "#| echo: true\n",
        "\n",
        "from pathlib import Path\n",
        "import subprocess\n",
        "\n",
        "import pynini\n",
        "import pywrapfst\n",
        "from IPython.display import Image, display\n",
        "\n",
        "\n",
        "def x(inp: str, out: str):\n",
        "    return pynini.cross(inp, out)\n",
        "\n",
        "\n",
        "def eps_out(out: str):\n",
        "    # epsilon on the input side, symbol on the output side\n",
        "    return pynini.cross(\"\", out)\n",
        "\n",
        "\n",
        "def byte_symbol_table(text: str):\n",
        "    syms = pywrapfst.SymbolTable()\n",
        "    syms.add_symbol(\"<eps>\", 0)\n",
        "    for ch in sorted(set(text)):\n",
        "        syms.add_symbol(ch, ord(ch))\n",
        "    return syms\n",
        "\n",
        "\n",
        "def apply_fst(fst, text: str):\n",
        "    lattice = pynini.accep(text) @ fst\n",
        "    try:\n",
        "        return pynini.shortestpath(lattice).string()\n",
        "    except pywrapfst.FstOpError:\n",
        "        return None\n",
        "\n",
        "\n",
        "# ---------- stems ----------\n",
        "# surface -> lexical stem\n",
        "\n",
        "run_stem = x(\"run\", \"run\")\n",
        "jump_stem = x(\"jump\", \"jump\")\n",
        "happy_stem = x(\"happi\", \"happy\")   # happiness surface stem -> lexical happy\n",
        "\n",
        "\n",
        "# ---------- suffixes ----------\n",
        "# boundary is inserted with epsilon:+\n",
        "\n",
        "ing_regular = eps_out(\"+\") + x(\"ing\", \"ing\")\n",
        "ing_after_n = eps_out(\"+\") + x(\"ning\", \"ing\")   # running: surface ning -> lexical ing\n",
        "ness = eps_out(\"+\") + x(\"ness\", \"ness\")\n",
        "\n",
        "\n",
        "# ---------- whole-word analyzers ----------\n",
        "running = run_stem + ing_after_n\n",
        "jumping = jump_stem + ing_regular\n",
        "happiness = happy_stem + ness\n",
        "\n",
        "fst = (running | jumping | happiness).optimize()\n",
        "\n",
        "\n",
        "# ---------- draw ----------\n",
        "all_symbols = \"runningjumpinghappinessrun+ingjump+inghappy+ness\"\n",
        "syms = byte_symbol_table(all_symbols)\n",
        "\n",
        "dot_path = Path(\"fst_morphology1.dot\")\n",
        "png_path = Path(\"fst_morphology1.png\")\n",
        "\n",
        "fst.draw(\n",
        "    str(dot_path),\n",
        "    portrait=True,\n",
        "    isymbols=syms,\n",
        "    osymbols=syms,\n",
        ")\n",
        "\n",
        "subprocess.run(\n",
        "    [\"dot\", \"-Tpng\", str(dot_path), \"-o\", str(png_path)],\n",
        "    check=True,\n",
        ")\n",
        "\n",
        "\n",
        "# ---------- test ----------\n",
        "for w in [\"running\", \"jumping\", \"happiness\", \"runner\"]:\n",
        "    print(f\"{w:10s} -> {apply_fst(fst, w)}\")\n",
        "\n",
        "#display(Image(filename=str(png_path)))"
