        "#| label: tagged-morphology\n",
        "#| echo: true\n",
        "\n",
        "from pathlib import Path\n",
        "import string\n",
        "import subprocess\n",
        "\n",
        "import pandas as pd\n",
        "import pynini\n",
        "import pywrapfst\n",
        "from pynini.lib import pynutil\n",
        "from IPython.display import Image, display\n",
        "\n",
        "\n",
        "# ----------------------------\n",
        "# Helpers\n",
        "# ----------------------------\n",
        "\n",
        "def accep(s: str):\n",
        "    return pynini.accep(s)\n",
        "\n",
        "\n",
        "def one_best(fst, text: str):\n",
        "    \"\"\"\n",
        "    Apply FST to text and return the best output string.\n",
        "    Returns None if the input is rejected.\n",
        "    \"\"\"\n",
        "    lattice = pynini.compose(accep(text), fst)\n",
        "\n",
        "    if lattice.start() == pywrapfst.NO_STATE_ID:\n",
        "        return None\n",
        "\n",
        "    try:\n",
        "        path = pynini.shortestpath(lattice, nshortest=1, unique=True).optimize()\n",
        "        path.project(\"output\")\n",
        "        path.rmepsilon()\n",
        "        return path.string()\n",
        "    except pywrapfst.FstOpError:\n",
        "        return None\n",
        "\n",
        "\n",
        "def byte_symbol_table(chars: str):\n",
        "    syms = pywrapfst.SymbolTable()\n",
        "    syms.add_symbol(\"<eps>\", 0)\n",
        "    for ch in sorted(set(chars)):\n",
        "        syms.add_symbol(ch, ord(ch))\n",
        "    return syms\n",
        "\n",
        "\n",
        "# ----------------------------\n",
        "# 1. Feature specs -> tagged analyses\n",
        "# ----------------------------\n",
        "\n",
        "FEATURE_TO_ANALYSIS = pynini.string_map([\n",
        "    # happy adjective family\n",
        "    (\"happy/ADJ\",              \"happy/STEM<ADJ>\"),\n",
        "    (\"happy/ADJ<NEG>\",         \"un/NEG+happy/STEM<ADJ>\"),\n",
        "    (\"happy/ADJ<COMP>\",        \"happy/STEM<ADJ>+er/COMP\"),\n",
        "    (\"happy/ADJ<NEG><COMP>\",   \"un/NEG+happy/STEM<ADJ>+er/COMP\"),\n",
        "    (\"happy/ADJ<SUP>\",         \"happy/STEM<ADJ>+est/SUP\"),\n",
        "    (\"happy/ADJ<NEG><SUP>\",    \"un/NEG+happy/STEM<ADJ>+est/SUP\"),\n",
        "    (\"happy/ADJ<NMLZ>\",        \"happy/STEM<ADJ>+ness/NMLZ<N>\"),\n",
        "    (\"happy/ADJ<NEG><NMLZ>\",   \"un/NEG+happy/STEM<ADJ>+ness/NMLZ<N>\"),\n",
        "\n",
        "    # run verb family\n",
        "    (\"run/VERB\",               \"run/STEM<VERB>\"),\n",
        "    (\"run/VERB<AGENT>\",        \"run/STEM<VERB>+er/AGENT<N>\"),\n",
        "    (\"run/VERB<PROG>\",         \"run/STEM<VERB>+ing/PROG\"),\n",
        "    (\"run/VERB<RE><PROG>\",     \"re/PREFIX+run/STEM<VERB>+ing/PROG\"),\n",
        "\n",
        "    # jump verb / adjective family\n",
        "    (\"jump/VERB\",              \"jump/STEM<VERB>\"),\n",
        "    (\"jump/VERB<PAST>\",        \"jump/STEM<VERB>+ed/PAST\"),\n",
        "    (\"jump/VERB<PROG>\",        \"jump/STEM<VERB>+ing/PROG\"),\n",
        "    (\"jump/VERB<AGENT>\",       \"jump/STEM<VERB>+er/AGENT<N>\"),\n",
        "    (\"jump/VERB<ADJZ>\",        \"jump/STEM<VERB>+y/ADJZ<ADJ>\"),\n",
        "\n",
        "    # derived adjective jumpy\n",
        "    (\"jumpy/ADJ\",              \"jumpy/STEM<ADJ>\"),\n",
        "    (\"jumpy/ADJ<COMP>\",        \"jumpy/STEM<ADJ>+er/COMP\"),\n",
        "    (\"jumpy/ADJ<SUP>\",         \"jumpy/STEM<ADJ>+est/SUP\"),\n",
        "]).optimize()\n",
        "\n",
        "\n",
        "# ----------------------------\n",
        "# 2. Tagged analyses -> underlying lexical forms\n",
        "# ----------------------------\n",
        "\n",
        "ANALYSIS_TO_LEXICAL = pynini.string_map([\n",
        "    # happy adjective family\n",
        "    (\"happy/STEM<ADJ>\",                         \"happy\"),\n",
        "    (\"un/NEG+happy/STEM<ADJ>\",                  \"un+happy\"),\n",
        "    (\"happy/STEM<ADJ>+er/COMP\",                 \"happy+er\"),\n",
        "    (\"un/NEG+happy/STEM<ADJ>+er/COMP\",          \"un+happy+er\"),\n",
        "    (\"happy/STEM<ADJ>+est/SUP\",                 \"happy+est\"),\n",
        "    (\"un/NEG+happy/STEM<ADJ>+est/SUP\",          \"un+happy+est\"),\n",
        "    (\"happy/STEM<ADJ>+ness/NMLZ<N>\",            \"happy+ness\"),\n",
        "    (\"un/NEG+happy/STEM<ADJ>+ness/NMLZ<N>\",     \"un+happy+ness\"),\n",
        "\n",
        "    # run family\n",
        "    (\"run/STEM<VERB>\",                          \"run\"),\n",
        "    (\"run/STEM<VERB>+er/AGENT<N>\",              \"run+er\"),\n",
        "    (\"run/STEM<VERB>+ing/PROG\",                 \"run+ing\"),\n",
        "    (\"re/PREFIX+run/STEM<VERB>+ing/PROG\",       \"re+run+ing\"),\n",
        "\n",
        "    # jump family\n",
        "    (\"jump/STEM<VERB>\",                         \"jump\"),\n",
        "    (\"jump/STEM<VERB>+ed/PAST\",                 \"jump+ed\"),\n",
        "    (\"jump/STEM<VERB>+ing/PROG\",                \"jump+ing\"),\n",
        "    (\"jump/STEM<VERB>+er/AGENT<N>\",             \"jump+er\"),\n",
        "    (\"jump/STEM<VERB>+y/ADJZ<ADJ>\",             \"jump+y\"),\n",
        "\n",
        "    # jumpy adjective family\n",
        "    (\"jumpy/STEM<ADJ>\",                         \"jumpy\"),\n",
        "    (\"jumpy/STEM<ADJ>+er/COMP\",                 \"jumpy+er\"),\n",
        "    (\"jumpy/STEM<ADJ>+est/SUP\",                 \"jumpy+est\"),\n",
        "]).optimize()\n",
        "\n",
        "\n",
        "# ----------------------------\n",
        "# 3. Spelling rules\n",
        "# ----------------------------\n",
        "\n",
        "ALPHABET = string.ascii_lowercase + \"+\"\n",
        "SIGMA_STAR = pynini.union(*ALPHABET).closure().optimize()\n",
        "\n",
        "PLUS = accep(\"+\")\n",
        "ER = accep(\"er\")\n",
        "EST = accep(\"est\")\n",
        "ING = accep(\"ing\")\n",
        "NESS = accep(\"ness\")\n",
        "\n",
        "\n",
        "# happy+er    -> happi+er\n",
        "# happy+est   -> happi+est\n",
        "# happy+ness  -> happi+ness\n",
        "# jumpy+er    -> jumpi+er\n",
        "# jumpy+est   -> jumpi+est\n",
        "y_to_i_before_suffix = pynini.cdrewrite(\n",
        "    pynini.cross(\"y\", \"i\"),\n",
        "    \"\",\n",
        "    PLUS + (ER | EST | NESS),\n",
        "    SIGMA_STAR,\n",
        ").optimize()\n",
        "\n",
        "\n",
        "# run+er  -> runn+er\n",
        "double_n_before_er = pynini.cdrewrite(\n",
        "    pynutil.insert(\"n\"),\n",
        "    accep(\"n\"),\n",
        "    PLUS + ER,\n",
        "    SIGMA_STAR,\n",
        ").optimize()\n",
        "\n",
        "\n",
        "# run+ing -> runn+ing\n",
        "double_n_before_ing = pynini.cdrewrite(\n",
        "    pynutil.insert(\"n\"),\n",
        "    accep(\"n\"),\n",
        "    PLUS + ING,\n",
        "    SIGMA_STAR,\n",
        ").optimize()\n",
        "\n",
        "\n",
        "# delete lexical morpheme boundaries\n",
        "delete_boundaries = pynini.cdrewrite(\n",
        "    pynutil.delete(\"+\"),\n",
        "    \"\",\n",
        "    \"\",\n",
        "    SIGMA_STAR,\n",
        ").optimize()\n",
        "\n",
        "\n",
        "SPELLING = (\n",
        "    y_to_i_before_suffix\n",
        "    @ double_n_before_er\n",
        "    @ double_n_before_ing\n",
        "    @ delete_boundaries\n",
        ").optimize()\n",
        "\n",
        "\n",
        "# ----------------------------\n",
        "# 4. Generators and analyzer\n",
        "# ----------------------------\n",
        "\n",
        "# Full tagged analysis -> surface\n",
        "GENERATOR = (\n",
        "    ANALYSIS_TO_LEXICAL\n",
        "    @ SPELLING\n",
        ").optimize()\n",
        "\n",
        "# Compact feature spec -> surface\n",
        "FEATURE_GENERATOR = (\n",
        "    FEATURE_TO_ANALYSIS\n",
        "    @ GENERATOR\n",
        ").optimize()\n",
        "\n",
        "# Surface -> full tagged analysis\n",
        "ANALYZER = GENERATOR.invert().optimize()\n",
        "\n",
        "\n",
        "# ----------------------------\n",
        "# 5. Test feature spec -> surface\n",
        "# ----------------------------\n",
        "\n",
        "feature_tests = [\n",
        "    \"happy/ADJ\",\n",
        "    \"happy/ADJ<NEG>\",\n",
        "    \"happy/ADJ<COMP>\",\n",
        "    \"happy/ADJ<NEG><COMP>\",\n",
        "    \"happy/ADJ<SUP>\",\n",
        "    \"happy/ADJ<NEG><SUP>\",\n",
        "    \"happy/ADJ<NMLZ>\",\n",
        "    \"happy/ADJ<NEG><NMLZ>\",\n",
        "\n",
        "    \"run/VERB\",\n",
        "    \"run/VERB<AGENT>\",\n",
        "    \"run/VERB<PROG>\",\n",
        "    \"run/VERB<RE><PROG>\",\n",
        "\n",
        "    \"jump/VERB\",\n",
        "    \"jump/VERB<PAST>\",\n",
        "    \"jump/VERB<PROG>\",\n",
        "    \"jump/VERB<AGENT>\",\n",
        "    \"jump/VERB<ADJZ>\",\n",
        "\n",
        "    \"jumpy/ADJ\",\n",
        "    \"jumpy/ADJ<COMP>\",\n",
        "    \"jumpy/ADJ<SUP>\",\n",
        "]\n",
        "\n",
        "feature_rows = [\n",
        "    {\"feature_spec\": x, \"surface\": one_best(FEATURE_GENERATOR, x)}\n",
        "    for x in feature_tests\n",
        "]\n",
        "\n",
        "display(pd.DataFrame(feature_rows))\n",
        "\n",
        "\n",
        "# ----------------------------\n",
        "# 6. Test tagged analysis -> surface\n",
        "# ----------------------------\n",
        "\n",
        "analysis_tests = [\n",
        "    \"un/NEG+happy/STEM<ADJ>+ness/NMLZ<N>\",\n",
        "    \"un/NEG+happy/STEM<ADJ>+er/COMP\",\n",
        "    \"re/PREFIX+run/STEM<VERB>+ing/PROG\",\n",
        "    \"jump/STEM<VERB>+y/ADJZ<ADJ>\",\n",
        "    \"jumpy/STEM<ADJ>+est/SUP\",\n",
        "]\n",
        "\n",
        "analysis_rows = [\n",
        "    {\"analysis\": x, \"surface\": one_best(GENERATOR, x)}\n",
        "    for x in analysis_tests\n",
        "]\n",
        "\n",
        "display(pd.DataFrame(analysis_rows))\n",
        "\n",
        "\n",
        "# ----------------------------\n",
        "# 7. Test surface -> tagged analysis\n",
        "# ----------------------------\n",
        "\n",
        "surface_tests = [\n",
        "    \"happy\",\n",
        "    \"unhappy\",\n",
        "    \"happier\",\n",
        "    \"unhappier\",\n",
        "    \"happiest\",\n",
        "    \"unhappiest\",\n",
        "    \"happiness\",\n",
        "    \"unhappiness\",\n",
        "\n",
        "    \"run\",\n",
        "    \"runner\",\n",
        "    \"running\",\n",
        "    \"rerunning\",\n",
        "\n",
        "    \"jump\",\n",
        "    \"jumped\",\n",
        "    \"jumping\",\n",
        "    \"jumper\",\n",
        "    \"jumpy\",\n",
        "    \"jumpier\",\n",
        "    \"jumpiest\",\n",
        "]\n",
        "\n",
        "surface_rows = [\n",
        "    {\"surface\": x, \"analysis\": one_best(ANALYZER, x)}\n",
        "    for x in surface_tests\n",
        "]\n",
        "\n",
        "display(pd.DataFrame(surface_rows))\n",
        "\n",
        "\n",
        "# ----------------------------\n",
        "# 8. Draw analyzer\n",
        "# ----------------------------\n",
        "\n",
        "draw_chars = (\n",
        "    string.ascii_lowercase\n",
        "    + \"+/<>\"\n",
        "    + \"ABCDEFGHIJKLMNOPQRSTUVWXYZ\"\n",
        ")\n",
        "\n",
        "syms = byte_symbol_table(draw_chars)\n",
        "\n",
        "dot_path = Path(\"tagged_morph_analyzer.dot\")\n",
        "png_path = Path(\"tagged_morph_analyzer.png\")\n",
        "\n",
        "ANALYZER.draw(\n",
        "    str(dot_path),\n",
