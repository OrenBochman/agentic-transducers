   "source": [
    "#| label: fig-fst-morphology\n",
    "#| fig-cap: Toy morphology FST\n",
    "#| echo: true\n",
    "\n",
    "#| label: fst-morphology\n",
    "#| echo: true\n",
    "\n",
    "import subprocess\n",
    "from pathlib import Path\n",
    "\n",
    "import pynini\n",
    "\n",
    "\n",
    "def x(inp: str, out: str):\n",
    "    \"\"\"Small alias for a one-symbol transducer.\"\"\"\n",
    "    return pynini.cross(inp, out)\n",
    "\n",
    "\n",
    "# This matches/transduces:\n",
    "# r (u|n)* i (n|g)*\n",
    "fst = (\n",
    "    x(\"r\", \"r\")\n",
    "    + pynini.closure(x(\"u\", \"u\") | x(\"n\", \"n\"))\n",
    "    + x(\"i\", \"i\")\n",
    "    + pynini.closure(x(\"n\", \"n\") | x(\"g\", \"g\"))\n",
    ")\n",
    "\n",
    "# Keep graph readable.\n",
    "fst = fst.optimize()\n",
    "\n",
    "dot_path = Path(\"fst_morphology.dot\")\n",
    "png_path = Path(\"fst_morphology.png\")\n",
    "\n",
    "# Pynini/OpenFst writes DOT; Graphviz turns DOT into PNG.\n",
    "fst.draw(str(dot_path), portrait=True)\n",
    "\n",
    "subprocess.run(\n",
    "    [\"dot\", \"-Tpng\", str(dot_path), \"-o\", str(png_path)],\n",
    "    check=True,\n",
    ")\n",
    "\n",
    "png_path"
   ]
  },
  {
