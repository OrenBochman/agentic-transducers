    "\n",
    "Define the FST\n",
    "\n",
    "We’ll create an FST that analyzes the word “running” into its root and suffix: “run+ing”."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "eae39f5d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "mo? -> ba!\n",
      "moo? -> baa!\n",
      "mooo? -> baaa!\n"
     ]
    }
   ],
   "source": [
    "import pynini\n",
    "\n",
    "o_to_a = pynini.cross(\"o\", \"a\")\n",
    "one_or_more_o_to_a = o_to_a + pynini.closure(o_to_a)\n",
    "\n",
    "rule = pynini.cross(\"m\", \"b\") + one_or_more_o_to_a + pynini.cross(\"?\", \"!\")\n",
    "\n",
    "for s in [\"mo?\", \"moo?\", \"mooo?\"]:\n",
    "    print(s, \"->\", pynini.shortestpath(s @ rule).string())"
   ]
  },
  {
